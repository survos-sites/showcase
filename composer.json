{
    "type": "project",
    "name": "survos-sites/showcase",
    "description": "A showcase of survos sites and asciicasts",
    "license": "proprietary",
    "prefer-stable": true,
    "minimum-stability": "dev",
    "require": {
        "php": "^8.5",
        "ext-ctype": "*",
        "ext-iconv": "*",
        "ext-intl": "*",
        "adhocore/cli-syntax": "^1.0",
        "api-platform/core": "^4.2",
        "bakame/html-table": "^0.5.0",
        "doctrine/dbal": "^4.4",
        "doctrine/doctrine-bundle": "^3",
        "doctrine/doctrine-migrations-bundle": "^4.0",
        "doctrine/orm": "^3.6",
        "easycorp/easyadmin-bundle": "^5.0",
        "friendsofsymfony/jsrouting-bundle": "^3.5",
        "helgesverre/toon": "^3.1",
        "inspector-apm/inspector-symfony": "^1.8",
        "jolicode/jolinotif": "^3.2",
        "knplabs/knp-time-bundle": "^2.4",
        "league/flysystem-aws-s3-v3": "^3.29",
        "league/flysystem-bundle": "^3.4",
        "liip/imagine-bundle": "^2.13",
        "nelmio/cors-bundle": "^2.4",
        "nikic/php-parser": "^5.0",
        "phpdocumentor/reflection-docblock": "^6.0",
        "roave/better-reflection": "^6.32",
        "sensiolabs/ansi-to-html": "^2.0",
        "survos/babel-bundle": "^2.0",
        "survos/ciine-bundle": "^2.0",
        "survos/data-contracts": "^2.11",
        "survos/ez-bundle": "^2.0",
        "survos/field-bundle": "^2.2",
        "survos/import-bundle": "^2.0",
        "survos/js-twig-bundle": "^2.10",
        "survos/jsonl-bundle": "^2.0",
        "survos/reveal-bundle": "^2.0",
        "survos/search-bundle": "^2.10.27",
        "survos/simple-datatables-bundle": "^2.0",
        "survos/state-bundle": "^2.0",
        "survos/storage-bundle": "^2.0",
        "survos/tabler-bundle": "dev-main",
        "symfony/asset": "^8.1",
        "symfony/asset-mapper": "^8.1",
        "symfony/console": "^8.1",
        "symfony/doctrine-messenger": "^8.1",
        "symfony/dotenv": "^8.1",
        "symfony/expression-language": "^8.1",
        "symfony/flex": "^2",
        "symfony/form": "^8.1",
        "symfony/framework-bundle": "^8.1",
        "symfony/http-client": "^8.1",
        "symfony/intl": "^8.1",
        "symfony/joli-notif-notifier": "^8.1",
        "symfony/mailer": "^8.1",
        "symfony/mime": "^8.1",
        "symfony/monolog-bundle": "^4.0",
        "symfony/notifier": "^8.1",
        "symfony/object-mapper": "^8.1",
        "symfony/process": "^8.1",
        "symfony/property-access": "^8.1",
        "symfony/property-info": "^8.1",
        "symfony/runtime": "^8.1",
        "symfony/security-bundle": "^8.1",
        "symfony/security-csrf": "^8.1",
        "symfony/serializer": "^8.1",
        "symfony/stimulus-bundle": "^3.0",
        "symfony/string": "^8.1",
        "symfony/translation": "^8.1",
        "symfony/twig-bundle": "^8.1",
        "symfony/ux-chartjs": "*",
        "symfony/ux-icons": "*",
        "symfony/ux-turbo": "^3.0",
        "symfony/validator": "^8.1",
        "symfony/web-link": "^8.1",
        "symfony/yaml": "^8.1",
        "twig/extra-bundle": "^3.0",
        "twig/twig": "^3.0"
    },
    "config": {
        "allow-plugins": {
            "endroid/installer": false,
            "php-http/discovery": true,
            "symfony/ai-mate-composer-plugin": true,
            "symfony/flex": true,
            "symfony/runtime": true
        },
        "sort-packages": true
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "App\\Tests\\": "tests/",
            "Mate\\": "mate/src/"
        }
    },
    "replace": {
        "symfony/polyfill-ctype": "*",
        "symfony/polyfill-iconv": "*",
        "symfony/polyfill-php72": "*",
        "symfony/polyfill-php73": "*",
        "symfony/polyfill-php74": "*",
        "symfony/polyfill-php80": "*",
        "symfony/polyfill-php81": "*",
        "symfony/polyfill-php82": "*"
    },
    "scripts": {
        "auto-scripts": {
            "fos:js-routing:dump --format=json --target=public/js/fos_js_routes.json": "symfony-cmd",
            "assets:install %PUBLIC_DIR%": "symfony-cmd",
            "importmap:install": "symfony-cmd"
        },
        "post-install-cmd": [
            "php -d memory_limit=512M bin/console cache:clear",
            "@auto-scripts"
        ],
        "post-update-cmd": [
            "php -d memory_limit=512M bin/console cache:clear",
            "@auto-scripts"
        ],
        "coverage": "rm var/test.db -f && bin/console d:sc:update --force --env=test && php -d xpcov.enabled=1 vendor/bin/phpunit --coverage-html coverage"
    },
    "conflict": {
        "symfony/symfony": "*"
    },
    "extra": {
        "symfony": {
            "allow-contrib": true
        },
        "ai-mate": {
            "extension": false,
            "scan-dirs": [
                "mate/src"
            ],
            "includes": [
                "mate/config.php"
            ]
        }
    },
    "require-dev": {
        "dbrekelmans/bdi": "^1.4",
        "phpstan/phpstan": "^2.0",
        "phpunit/phpunit": "^13.1",
        "rector/rector": "^2.0",
        "survos/code-bundle": "dev-main",
        "survos/command-bundle": "^2.10",
        "survos/crawler-bundle": "^2.0",
        "survos/deployment-bundle": "^2.0",
        "survos/doc-bundle": "^2.0",
        "symfony/ai-mate": "^0.10.0",
        "symfony/browser-kit": "^8.1",
        "symfony/css-selector": "^8.1",
        "symfony/debug-bundle": "^8.1",
        "symfony/maker-bundle": "^1.57",
        "symfony/panther": "^2.3",
        "symfony/phpunit-bridge": "^8.1",
        "symfony/stopwatch": "^8.1",
        "symfony/web-profiler-bundle": "^8.1",
        "zenstruck/browser": "^1.8",
        "zenstruck/console-test": "^1.7"
    }
}
