<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reveal Slideshow</title>

    {# reveal.js CSS (base + black theme + highlight) is loaded via the
       @survos/reveal-bundle stimulus controller's importmap autoimport #}

    <style>
        body, html {
            margin: 0;
            padding: 0;
            height: 100%;
            overflow: hidden;
        }
        .reveal {
            width: 100vw;
            height: 100vh;
        }
    </style>

    {# Asset Mapper imports #}
    {% block importmap %}
        {{ importmap('app') }}
    {% endblock %}
</head>
<body>
{% set _sc = '@survos/reveal-bundle/reveal' %}

<div class="reveal" {{ stimulus_controller(_sc) }}>
    <div class="slides">
        <section>
            <h2>Bullet Points</h2>
            <pre><code class="language-bash" data-lang="bash">
symfony new --webapp movies && cd movies
composer req survos/meili-bundle easycorp/easyadmin
composer req survos/code-bundle --dev
            </code>
                </pre>


            <ul>
                <li>App Bundles</li>
                <li>Dev Bundles</li>
            </ul>
        </section>

            <section>

                <pre><code class="language-php">
function hello($name) {
    return "Hello, $name!";
}
                </code></pre>
            </section>

        <section>
            <h2>More Bullet Points</h2>
            <ul>
                <li>Point one</li>
                <li>Point two</li>
            </ul>
        </section>
    </div>
</div>
</body>
</html>
