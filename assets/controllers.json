{
    "controllers": {
        "@survos/js-twig-bundle": {
            "dexie": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": []
            },
            "js_twig": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            }
        },
        "@survos/reveal-bundle": {
            "reveal": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "reveal.js/dist/reveal.js": true,
                    "reveal.js/dist/reveal.css": true,
                    "reveal.js/dist/theme/black.css": true
                }
            }
        },
        "@survos/simple-datatables-bundle": {
            "table": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "@survos/simple-datatables/style.css": true
                }
            }
        },
        "@survos/state-bundle": {
            "workflow": {
                "enabled": true,
                "fetch": "eager"
            }
        },
        "@survos/tabler-bundle": {
            "accordion": {
                "enabled": true,
                "fetch": "lazy"
            },
            "search": {
                "enabled": true,
                "fetch": "lazy"
            }
        },
        "@symfony/ux-chartjs": {
            "chart": {
                "enabled": true,
                "fetch": "eager"
            }
        },
        "@symfony/ux-live-component": {
            "live": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "@symfony/ux-live-component/dist/live.min.css": true
                }
            }
        },
        "@symfony/ux-turbo": {
            "turbo-core": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "@symfony/ux-turbo/dist/mercure_stream_source_element.js": true
                }
            },
            "mercure-turbo-stream": {
                "enabled": false,
                "fetch": "eager"
            }
        },
        "@tacman/ux-search": {
            "ux-search": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "@tacman/ux-search/dist/default.min.css": true
                }
            },
            "ux-search--refinement-list": {
                "enabled": true,
                "fetch": "eager"
            },
            "ux-search-range-slider": {
                "enabled": true,
                "fetch": "eager"
            }
        }
    },
    "entrypoints": []
}
