{
    "controllers": {
        "@survos/js-twig-bundle": {
            "dexie": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": []
            },
            "js_twig": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            }
        },
        "@survos/meili-bundle": {
            "insta": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "instantsearch.css/themes/algolia.min.css": true,
                    "pretty-print-json/dist/css/pretty-print-json.min.css": true
                }
            },
            "json": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": []
            },
            "chat": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "@survos/meili/styles/chat.css": true
                }
            }
        },
        "@survos/reveal-bundle": {
            "reveal": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "reveal.js/dist/reveal.js": true,
                    "reveal.js/dist/reveal.css": true,
                    "reveal.js/dist/theme/black.css": true
                }
            }
        },
        "@survos/simple-datatables-bundle": {
            "table": {
                "enabled": true,
                "fetch": "lazy",
                "autoimport": {
                    "@survos/simple-datatables/style.css": true
                }
            }
        },
        "@survos/state-bundle": {
            "workflow": {
                "enabled": true,
                "fetch": "eager"
            }
        },
        "@survos/tabler-bundle": {
            "accordion": {
                "enabled": true,
                "fetch": "lazy"
            },
            "search": {
                "enabled": true,
                "fetch": "lazy"
            }
        },
        "@symfony/ux-chartjs": {
            "chart": {
                "enabled": true,
                "fetch": "eager"
            }
        },
        "@symfony/ux-turbo": {
            "turbo-core": {
                "enabled": true,
                "fetch": "eager",
                "autoimport": {
                    "@symfony/ux-turbo/dist/mercure_stream_source_element.js": true
                }
            },
            "mercure-turbo-stream": {
                "enabled": false,
                "fetch": "eager"
            }
        }
    },
    "entrypoints": []
}
